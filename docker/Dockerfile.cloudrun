# ============================================================
# Stage 1: Build the picoclaw binary
# ============================================================
FROM golang:1.25-alpine AS builder

RUN apk add --no-cache git make

WORKDIR /src

# Cache dependencies
COPY go.mod go.sum ./
RUN go mod download

# Copy source and build
COPY . .
ARG GO_BUILD_TAGS=goolm,stdjson
RUN make build GO_BUILD_TAGS=${GO_BUILD_TAGS}

# ============================================================
# Stage 2: Runtime image with OpenVPN
# ============================================================
FROM alpine:3.23

# Install runtime dependencies including OpenVPN
RUN apk add --no-cache \
    ca-certificates \
    tzdata \
    curl \
    openvpn \
    iptables \
    iproute2

# Create OpenVPN config directory
RUN mkdir -p /etc/openvpn /var/log

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget -q --spider http://localhost:18790/health || exit 1

# Copy binary and entrypoints
COPY --from=builder /src/build/picoclaw /usr/local/bin/picoclaw
COPY docker/entrypoint.sh /entrypoint.sh
COPY docker/vpn-entrypoint.sh /vpn-entrypoint.sh
RUN chmod +x /entrypoint.sh /vpn-entrypoint.sh

# Use VPN-aware entrypoint
ENTRYPOINT ["/vpn-entrypoint.sh"]
